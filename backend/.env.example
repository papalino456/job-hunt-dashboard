# PostgreSQL Database URL (required for production)
# Get this from Render Dashboard → PostgreSQL → Connections
DATABASE_URL=postgresql://user:password@host:5432/database

# Login password for the dashboard (required)
PASSWORD=your-secure-password-here

# Session secret (auto-generated if not set, but recommended to set manually)
SESSION_SECRET=your-random-session-secret-32-chars-min

# Node environment
NODE_ENV=development

# Server port (Render uses 10000, local uses 3001)
PORT=3001

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000
